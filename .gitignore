# Local data and backups (don't ever commit session CSVs)
*.csv
CSV Dates/
_local_snapshot_*/

# Image assets used during design, not source of truth
*.jpg
*.png
!icon.png

# Build / dependency dirs (if we later move to React/Vite)
node_modules/
dist/
.vercel/
.vite/
.cache/

# Capacitor Android build artefacts. The android/ project is generated from
# mobile/package.json + capacitor.config.json, www/ is generated from the
# repo-root HTMLs by the copy-web script, and any signing material must
# never hit git.
mobile/node_modules/
mobile/www/
mobile/android/
mobile/ios/
mobile/*.keystore
mobile/*.keystore.b64
mobile/*.jks
mobile/sha1.txt
mobile/keystore-password.txt
mobile/release/

# Native Android (Kotlin + Compose) build artefacts. android/ is source-
# of-truth for the native app — keep the source, drop the build tree and
# signing material.
android/.gradle/
android/build/
android/**/build/
android/local.properties
android/*.keystore
android/*.jks
android/keystore.properties
android/captures/
android/.idea/
android/.cxx/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Claude local context (not part of the shipped app)
SESSION_LOG.md
CLAUDE.md
