# Local data and backups (don't ever commit session CSVs)
*.csv
CSV Dates/
_local_snapshot_*/

# Secrets. NEVER commit. Google OAuth client JSON files, .env files,
# private keys, anything that looks like a credential. The canonical
# home for this project's secrets is C:/Users/Khal/.secrets/aorti/.
client_secret*.json
credentials*.json
*.env
*.env.*
!.env.example
*.pem
*.key
service-account*.json

# Image assets: scratch images at root stay untracked, but the /assets
# tree (brand logos + product screenshots shown on the landing page) IS
# committed so Vercel can serve them.
*.jpg
*.png
!icon.png
!/assets/**


# Build / dependency dirs (if we later move to React/Vite)
node_modules/
dist/
.vercel/
.vite/
.cache/

# Capacitor Android build artefacts. The android/ project is generated from
# mobile/package.json + capacitor.config.json, www/ is generated from the
# repo-root HTMLs by the copy-web script, and any signing material must
# never hit git.
mobile/node_modules/
mobile/www/
mobile/android/
mobile/ios/
mobile/*.keystore
mobile/*.keystore.b64
mobile/*.jks
mobile/sha1.txt
mobile/keystore-password.txt
mobile/release/

# Native Android (Kotlin + Compose) build artefacts. android/ is source-
# of-truth for the native app — keep the source, drop the build tree and
# signing material.
android/.gradle/
android/build/
android/**/build/
android/local.properties
android/*.keystore
android/*.jks
android/keystore.properties
android/captures/
android/.idea/
android/.cxx/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Claude local context (not part of the shipped app)
SESSION_LOG.md
CLAUDE.md
TODO.md
docs/MOBILE_LAUNCH_PLAN.md
docs/baseline_thresholds_plan.md

# Organised local-only directories created during the rebrand cleanup.
# backups/ holds the pre-rebrand HTML snapshots (diff / revert source).
# _scratch/ holds throwaway design refs, screenshots we didn't ship, and
# error logs pulled during debugging.
backups/
_scratch/
_local/

